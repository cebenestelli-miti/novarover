Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Name: Tool Properties
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160;160;160
      Enabled: true
      Name: Grid
      Plane: XY
      Plane Cell Count: 20
      Reference Frame: odom
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
    - Class: rviz_default_plugins/RobotModel
      Enabled: true
      Name: RobotModel
      TF Prefix: ""
    - Alpha: 1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 200
      Name: Odometry
      Position Tolerance: 0.01
      Topic:
        Value: /odom
      Twist Color: 255;25;0
      Value: true
    - Alpha: 1
      Buffer Length: 1000
      Class: rviz_default_plugins/Path
      Color: 25;255;0
      Enabled: true
      Line Style: Lines
      Line Width: 0.05
      Name: Path
      Topic:
        Value: /mission/path
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Waypoints
      Topic:
        Value: /mission/waypoints_markers
  Enabled: true
  Global Options:
    Background Color: 30;30;30
    Fixed Frame: odom
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic:
        Value: /clicked_point
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 15
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Pitch: 0.785
      Yaw: 0.785
      Name: Orbit
    Saved: []
Window Geometry:
  Height: 800
  Width: 1200
  X: 50
  Y: 50

