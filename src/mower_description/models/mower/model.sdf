<?xml version="1.0"?>
<sdf version="1.9">
  <model name="mower">
    <static>false</static>
    <link name="base_link">
      <pose>0 0 0.15 0 0 0</pose>
      <inertial>
        <mass>50</mass>
        <inertia>
          <ixx>2.0</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.0</iyy><iyz>0</iyz><izz>1.0</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box><size>0.8 0.5 0.2</size></box>
        </geometry>
        <surface><friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction></surface>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box><size>0.8 0.5 0.2</size></box>
        </geometry>
        <material><ambient>0.2 0.5 0.2 1</ambient><diffuse>0.2 0.5 0.2 1</diffuse></material>
      </visual>
      <!-- Ultrasonic sensors (simulated with range sensor; Harmonic has no dedicated ultrasonic type): 0=front left, 1=front middle, 2=front right, 3=left side, 4=right side, 5=rear. Update poses to match real robot. -->
      <sensor name="ultrasonic_0" type="gpu_lidar">
        <pose>0.35 0.15 0.1 0 0 0.785</pose>
        <topic>/model/mower/ultrasonic/0</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <sensor name="ultrasonic_1" type="gpu_lidar">
        <pose>0.4 0 0.1 0 0 0</pose>
        <topic>/model/mower/ultrasonic/1</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <sensor name="ultrasonic_2" type="gpu_lidar">
        <pose>0.35 -0.15 0.1 0 0 -0.785</pose>
        <topic>/model/mower/ultrasonic/2</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <sensor name="ultrasonic_3" type="gpu_lidar">
        <pose>0 0.25 0.1 0 0 1.5708</pose>
        <topic>/model/mower/ultrasonic/3</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <sensor name="ultrasonic_4" type="gpu_lidar">
        <pose>0 -0.25 0.1 0 0 -1.5708</pose>
        <topic>/model/mower/ultrasonic/4</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <sensor name="ultrasonic_5" type="gpu_lidar">
        <pose>-0.35 0 0.1 0 0 3.14159</pose>
        <topic>/model/mower/ultrasonic/5</topic>
        <update_rate>20</update_rate>
        <ray>
          <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal><vertical><samples>1</samples><resolution>0.01</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan>
          <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
        </ray>
        <always_on>1</always_on>
      </sensor>
      <!-- IMU (optional: for use_ekf:=true). Frame base_link, REP-103. -->
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <topic>/model/mower/imu</topic>
        <update_rate>100</update_rate>
        <always_on>1</always_on>
      </sensor>
      <!-- GPS (optional: for use_ekf:=true use_gps:=true). World must define spherical_coordinates. -->
      <sensor name="gps_sensor" type="navsat">
        <pose>0 0 0 0 0 0</pose>
        <topic>/model/mower/gps/fix</topic>
        <update_rate>10</update_rate>
        <always_on>1</always_on>
      </sensor>
    </link>
    <link name="left_wheel">
      <pose>0 0.25 0.1 0 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <!-- Rotate cylinder so its axis aligns with the joint (y-axis) -->
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <!-- Match visual orientation to collision (wheel lying vertical, rolling around y) -->
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name="right_wheel">
      <pose>0 -0.25 0.1 0 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <!-- Rotate cylinder so its axis aligns with the joint (y-axis) -->
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <!-- Match visual orientation to collision (wheel lying vertical, rolling around y) -->
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/model/mower/cmd_vel</topic>
      <odom_topic>/model/mower/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </model>
</sdf>
